# Hugging Face Inference API Configuration (Primary AI Provider)
# Set your Hugging Face API token to enable AI-enhanced explanations and summaries
VITE_HF_API_TOKEN=your_huggingface_token_here

# Firebase Configuration (Required for authentication)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Legacy Gemini Configuration (for existing TaxationPage demo only)
VITE_GEMINI_API_KEY=your_gemini_api_key_here